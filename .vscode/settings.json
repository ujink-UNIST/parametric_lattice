{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.defaultInterpreterPath": "C:\\Users\\USER\\.conda\\envs\\param_lattice\\python.exe",
    "psi-header.config": {
        "author": "김우진",
        "authorEmail": "ujink1225@unist.ac.kr",
        "company": "UNIST UCIM Lab",
        "projectRootPath": "c:\\Users\\USER\\Documents\\parametric_lattice",
        "forceToTop": true
    },
    "psi-header.changes-tracking": {
        "isActive": true,
        "modDateFormat": "YYYY-MM-DD"
    },
    "psi-header.templates": [
        {
            "language": "*",
            "template": [
                "<<filename>>"
            ]
        }
    ],
    "psi-header.lang-config": [
        {
            "language": "python",
            "begin": "",
            "prefix": "# ",
            "end": ""
        }
    ],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "black-formatter.args": [
        "--line-length",
        "60"
    ],
    "[json]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "workbench.editorAssociations": {
        "*.xlsm": "default"
    }
}